# ===================================================================
# Provider Configuration with Cross-Subscription DNS Support
# ===================================================================
# This example demonstrates dual-provider setup for scenarios where:
# - Service resources (ACR, KeyVault, CosmosDB, etc.) deploy to WORKLOAD subscription
# - Private DNS Zones exist in a separate DNS/HUB subscription
# 
# Use this pattern when use_existing_private_dns = true
# ===================================================================

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.0"
    }
  }
}

# ===================================================================
# Provider: Default (Workload Subscription)
# ===================================================================
# Deploys service infrastructure: VMs, ACR, KeyVault, CosmosDB, etc.
# Also used for Private Endpoints in the workload VNet
# ===================================================================

provider "azurerm" {
  features {
    # Resource Group deletion behavior
    resource_group {
      prevent_deletion_if_contains_resources = false
    }

    # Virtual Machine features
    virtual_machine {
      delete_os_disk_on_deletion     = true
      skip_shutdown_and_force_delete = false
    }

    # Key Vault features
    key_vault {
      purge_soft_delete_on_destroy    = false
      recover_soft_deleted_key_vaults = true
    }
  }

  subscription_id = var.workload_subscription_id
  tenant_id       = var.tenant_id

  # Authentication methods (in priority order):
  # 1. Service Principal: ARM_CLIENT_ID, ARM_CLIENT_SECRET, ARM_TENANT_ID
  # 2. Azure CLI: az login
  # 3. Managed Identity: When running in Azure (e.g., Azure DevOps, GitHub Actions)
}

# ===================================================================
# Provider: DNS Subscription (Cross-Subscription DNS Management)
# ===================================================================
# Used ONLY when use_existing_private_dns = true
# Accesses existing Private DNS Zones in a separate subscription
# 
# The private-dns-registration module uses this provider alias to:
# - Reference existing Private DNS Zones
# - Create DNS A records for Private Endpoints
# 
# Note: VNet peering between workload VNet and DNS VNet is required
#       and must be configured separately (manual or separate automation)
# ===================================================================

provider "azurerm" {
  alias = "dns_sub"
  features {
    resource_group {
      prevent_deletion_if_contains_resources = false
    }
  }

  subscription_id = var.dns_subscription_id
  tenant_id       = var.tenant_id

  # Requires appropriate RBAC permissions in DNS subscription:
  # - Private DNS Zone Contributor (or DNS Zone Contributor)
  # - Reader (to reference existing zones)
}

# ===================================================================
# Required Variables for Provider Configuration
# ===================================================================
# 
# variable "workload_subscription_id" {
#   description = "Subscription where service resources deploy"
#   type        = string
# }
# 
# variable "dns_subscription_id" {
#   description = "Subscription where Private DNS Zones exist (required only when use_existing_private_dns = true)"
#   type        = string
# }
# 
# variable "tenant_id" {
#   description = "Azure AD Tenant ID"
#   type        = string
# }
# 
# variable "use_existing_private_dns" {
#   description = "Use existing Private DNS Zones in separate subscription (true) or create standalone zones (false)"
#   type        = bool
#   default     = false
# }
# ===================================================================

# ===================================================================
# IMPORTANT: VNet Peering Requirements
# ===================================================================
# When use_existing_private_dns = true, VNet peering is required between:
# - Workload VNet (where Private Endpoints are deployed)
# - DNS Hub VNet (where Private DNS Zone is linked)
# 
# This peering is intentionally NOT managed by this Terraform configuration.
# Reasons:
# 1. VNet peering is typically part of hub-spoke network architecture
# 2. Managed by network team or centralized network automation
# 3. Requires coordination between subscriptions
# 4. Should persist beyond lifecycle of individual service deployments
# 
# Manual steps or separate automation should establish:
# - Bidirectional VNet peering
# - Appropriate route tables
# - NSG rules allowing DNS traffic (UDP 53)
# ===================================================================
