#!/bin/bash
# ===================================================================
# Terraform Environment Scaffolder
# ===================================================================
# Interactively scaffolds a new Terraform environment using UAT
# environment files as templates with intelligent substitution.
# ===================================================================

set -e

# Color codes for terminal output
readonly CYAN='\033[0;36m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly RED='\033[0;31m'
readonly NC='\033[0m' # No Color
readonly BOLD='\033[1m'
readonly BLUE='\033[0;34m'

# Paths
readonly UAT_ENV_DIR="environments/uat"
readonly MODULES_DIR="modules"

# Available modules to select
declare -a MODULES=(
  "azure-acr"
  "azure-aks"
  "azure-cosmosdb"
  "azure-keyvault"
  "azure-redis"
  "azure-vm"
)

# Global variables (populated during script execution)
declare -a SELECTED_MODULES=()
declare PROJECT_NAME=""
declare ENV_NAME=""

# ===================================================================
# UI Functions
# ===================================================================

# Numbered list module selector
show_module_selector() {
  echo -e "${BOLD}${CYAN}═══════════════════════════════════════════════════${NC}"
  echo -e "${BOLD}${CYAN}  Terraform Environment Scaffolder${NC}"
  echo -e "${BOLD}${CYAN}═══════════════════════════════════════════════════${NC}"
  echo ""
  echo -e "${BOLD}Available modules:${NC}"
  echo ""
  
  # Print numbered list of modules
  for i in "${!MODULES[@]}"; do
    local num=$((i + 1))
    echo -e "  ${GREEN}${num}.${NC} ${MODULES[$i]}"
  done
  
  echo ""
  echo -e "Enter module numbers separated by spaces (e.g., ${GREEN}1 3 5${NC}), or ${GREEN}all${NC} to select everything:"
  read -r selection
  
  # Handle "all" selection
  if [ "$selection" = "all" ]; then
    SELECTED_MODULES=("${MODULES[@]}")
    return
  fi
  
  # Parse space-separated numbers
  SELECTED_MODULES=()
  local -a selected_indices=()
  
  for num in $selection; do
    # Validate that input is a number
    if ! [[ "$num" =~ ^[0-9]+$ ]]; then
      echo -e "${RED}Error: '$num' is not a valid number${NC}"
      exit 1
    fi
    
    # Convert to 0-based index
    local idx=$((num - 1))
    
    # Validate range
    if [ "$idx" -lt 0 ] || [ "$idx" -ge "${#MODULES[@]}" ]; then
      echo -e "${RED}Error: Number '$num' is out of range (valid: 1-${#MODULES[@]})${NC}"
      exit 1
    fi
    
    # Add to selected indices (avoid duplicates)
    if [[ ! " ${selected_indices[@]} " =~ " ${idx} " ]]; then
      selected_indices+=("$idx")
      SELECTED_MODULES+=("${MODULES[$idx]}")
    fi
  done
  
  # Validate at least one module is selected
  if [ "${#SELECTED_MODULES[@]}" -eq 0 ]; then
    echo -e "${RED}Error: No modules selected. Please select at least one module.${NC}"
    exit 1
  fi
}

# ===================================================================
# Template Processing Functions
# ===================================================================

# Perform substitutions on content
substitute_content() {
  local content="$1"
  local project_name="$2"
  local env_name="$3"
  
  # Replace "uat" with new environment name (case-insensitive patterns)
  content=$(echo "$content" | sed -e "s/\buat\b/${env_name}/g")
  content=$(echo "$content" | sed -e "s/\bUAT\b/${env_name^^}/g")
  content=$(echo "$content" | sed -e "s/\bUat\b/${env_name^}/g")
  
  # Replace rg-*-uat patterns
  content=$(echo "$content" | sed -e "s/rg-\([^-]*\)-uat/rg-\1-${env_name}/g")
  
  # Replace *-uat-* patterns
  content=$(echo "$content" | sed -e "s/-uat-/-${env_name}-/g")
  
  # Replace project_name value if present
  content=$(echo "$content" | sed -e "s/project_name = \"[^\"]*\"/project_name = \"${project_name}\"/g")
  
  echo "$content"
}

# Check if module is in selected list
is_module_selected() {
  local module_name="$1"
  for selected in "${SELECTED_MODULES[@]}"; do
    if [ "$selected" = "$module_name" ]; then
      return 0
    fi
  done
  return 1
}

# Extract module name from module block
get_module_name_from_block() {
  local block="$1"
  echo "$block" | grep -oP 'module\s+"\K[^"]+' | head -1
}

# Get module source path from block
get_module_source_from_block() {
  local block="$1"
  echo "$block" | grep -oP 'source\s+=\s+"[^"]*modules/\K[^"]+' | head -1
}

# Process main.tf from UAT template
process_main_tf() {
  local template_file="${UAT_ENV_DIR}/main.tf"
  local project_name="$1"
  local env_name="$2"
  
  if [ ! -f "$template_file" ]; then
    echo -e "${YELLOW}Warning: UAT main.tf not found, falling back to hardcoded template${NC}" >&2
    generate_main_tf_fallback "$env_name"
    return
  fi
  
  local content=$(cat "$template_file")
  
  # Split content into sections: before modules, module blocks, after modules
  local before_modules=$(echo "$content" | awk '/^# -------------------------------------------------------------------/{p=1} p{print} /^module\s+"/{exit}')
  local modules_section=$(echo "$content" | awk '/^module\s+"/{p=1} p{print; if(/^}$/ && p==1){p=0; print ""}}')
  
  # Process header section (terraform, provider, resource_group, VNet, subnets)
  local processed_content=$(substitute_content "$before_modules" "$project_name" "$env_name")
  
  # Process each module block
  while IFS= read -r line; do
    if [[ "$line" =~ ^module[[:space:]]+ ]]; then
      # Start of a new module block
      current_block="$line"
      in_block=1
    elif [ "$in_block" = "1" ]; then
      current_block="${current_block}"$'\n'"${line}"
      
      if [ "$line" = "}" ]; then
        # End of module block
        in_block=0
        
        # Extract module source
        local module_source=$(get_module_source_from_block "$current_block")
        
        # Check if this module is selected
        if is_module_selected "$module_source"; then
          # Include this module block with substitutions
          local processed_block=$(substitute_content "$current_block" "$project_name" "$env_name")
          processed_content="${processed_content}"$'\n\n'"${processed_block}"
        fi
        
        current_block=""
      fi
    fi
  done <<< "$modules_section"
  
  echo "$processed_content"
}

# Process variables.tf from UAT template
process_variables_tf() {
  local template_file="${UAT_ENV_DIR}/variables.tf"
  local env_name="$1"
  
  if [ ! -f "$template_file" ]; then
    echo -e "${YELLOW}Warning: UAT variables.tf not found, using minimal template${NC}" >&2
    generate_variables_tf_fallback "$env_name"
    return
  fi
  
  local content=$(cat "$template_file")
  
  # Perform substitutions (variables.tf typically doesn't need env-specific changes)
  echo "$content"
}

# Process backend.tf from UAT template
process_backend_tf() {
  local template_file="${UAT_ENV_DIR}/backend.tf"
  local env_name="$1"
  
  if [ ! -f "$template_file" ]; then
    return # backend.tf is optional
  fi
  
  local content=$(cat "$template_file")
  
  # Perform substitutions
  substitute_content "$content" "" "$env_name"
}

# Extract variables from a module's variables.tf and generate tfvars entries
generate_module_tfvars() {
  local module_name="$1"
  local project_name="$2"
  local env_name="$3"
  local module_vars_file="${MODULES_DIR}/${module_name}/variables.tf"
  
  if [ ! -f "$module_vars_file" ]; then
    echo "# WARNING: Module ${module_name} variables.tf not found"
    return
  fi
  
  echo ""
  echo "# ==================================================================="
  echo "# ${module_name} Configuration"
  echo "# ==================================================================="
  
  # Parse variables from the module's variables.tf
  local in_variable=0
  local var_name=""
  local var_description=""
  local var_default=""
  local var_type=""
  
  while IFS= read -r line; do
    # Detect variable block start
    if [[ "$line" =~ ^variable[[:space:]]\"([^\"]+)\" ]]; then
      in_variable=1
      var_name="${BASH_REMATCH[1]}"
      var_description=""
      var_default=""
      var_type=""
    elif [ "$in_variable" = "1" ]; then
      # Extract description
      if [[ "$line" =~ description[[:space:]]*=[[:space:]]*\"([^\"]+)\" ]]; then
        var_description="${BASH_REMATCH[1]}"
      fi
      
      # Extract default value
      if [[ "$line" =~ default[[:space:]]*=[[:space:]]*(.+) ]]; then
        var_default="${BASH_REMATCH[1]}"
      fi
      
      # Extract type
      if [[ "$line" =~ type[[:space:]]*=[[:space:]]*(.+) ]]; then
        var_type="${BASH_REMATCH[1]}"
      fi
      
      # Detect end of variable block
      if [[ "$line" =~ ^}$ ]]; then
        in_variable=0
        
        # Generate tfvars entry for this variable
        # Skip internal/computed variables like location, resource_group_name, etc.
        if [[ ! "$var_name" =~ ^(location|resource_group_name|tags|vnet_id|pe_subnet_id|aks_subnet_id)$ ]]; then
          # Generate appropriate value based on variable name and default
          local value=""
          
          if [ -n "$var_default" ]; then
            value="$var_default"
          else
            # Generate placeholder based on variable name patterns
            if [[ "$var_name" =~ project_name ]]; then
              value="\"${project_name}\""
            elif [[ "$var_name" =~ environment ]]; then
              value="\"${env_name}\""
            elif [[ "$var_name" =~ _name$ ]]; then
              value="\"TODO: ${var_description}\""
            elif [[ "$var_type" =~ bool ]]; then
              value="false"
            elif [[ "$var_type" =~ number ]]; then
              value="0"
            elif [[ "$var_type" =~ list ]]; then
              value="[]"
            else
              value="\"TODO: ${var_description}\""
            fi
          fi
          
          # Output the tfvars line with comment
          if [ -n "$var_description" ]; then
            echo "# ${var_description}"
          fi
          echo "${var_name} = ${value}"
          echo ""
        fi
      fi
    fi
  done < "$module_vars_file"
}

# Process terraform.tfvars from UAT template
process_terraform_tfvars() {
  local template_file="${UAT_ENV_DIR}/terraform.tfvars"
  local project_name="$1"
  local env_name="$2"
  
  if [ ! -f "$template_file" ]; then
    echo -e "${YELLOW}Warning: UAT terraform.tfvars not found, generating from scratch${NC}" >&2
    generate_terraform_tfvars_from_scratch "$project_name" "$env_name"
    return
  fi
  
  local content=$(cat "$template_file")
  
  # Perform basic substitutions
  content=$(substitute_content "$content" "$project_name" "$env_name")
  
  # Split into header and module sections
  # Keep everything up to the first module configuration section
  local header=$(echo "$content" | awk '
    /^# ===================================================================$/ {
      if (in_module) exit
      if ($0 ~ /Azure (Container Registry|Key Vault|Redis|Kubernetes|Cosmos)/) {
        in_module=1
        exit
      }
    }
    !in_module {print}
  ')
  
  echo "$header"
  
  # Generate module-specific tfvars for each selected module
  for module in "${SELECTED_MODULES[@]}"; do
    generate_module_tfvars "$module" "$project_name" "$env_name"
  done
}

# Generate terraform.tfvars from scratch if UAT template doesn't exist
generate_terraform_tfvars_from_scratch() {
  local project_name="$1"
  local env_name="$2"
  
  cat <<EOF
# ===================================================================
# ${env_name^} Environment - Terraform Variables
# ===================================================================
# Configuration values for the ${env_name} environment
# IMPORTANT: Update these values according to your requirements
# ===================================================================

# Project Configuration
project_name = "${project_name}"
environment  = "${env_name}"
location     = "Southeast Asia"

# Network Configuration
vnet_address_space         = ["10.10.0.0/16"]
pe_subnet_address_prefixes = ["10.10.2.0/24"]

# Resource Tags
tags = {
  Environment = "${env_name^}"
  Project     = "${project_name}"
  ManagedBy   = "Terraform"
  CreatedDate = "$(date +%Y-%m-%d)"
}
EOF

  # Generate module-specific tfvars
  for module in "${SELECTED_MODULES[@]}"; do
    generate_module_tfvars "$module" "$project_name" "$env_name"
  done
}

# ===================================================================
# Fallback Functions (Used if UAT templates don't exist)
# ===================================================================

# Check if private endpoints are needed
needs_private_endpoints() {
  local modules=("$@")
  for mod in "${modules[@]}"; do
    case "$mod" in
      azure-acr|azure-keyvault|azure-cosmosdb|azure-redis)
        return 0
        ;;
    esac
  done
  return 1
}

# Check if AKS subnet is needed
needs_aks_subnet() {
  local modules=("$@")
  for mod in "${modules[@]}"; do
    if [ "$mod" = "azure-aks" ]; then
      return 0
    fi
  done
  return 1
}

# Minimal fallback main.tf generator
generate_main_tf_fallback() {
  local env_name="$1"
  
  cat <<EOF
# ===================================================================
# ${env_name^} Environment - Main Configuration
# ===================================================================
# WARNING: Generated from fallback template (UAT template not found)
# ===================================================================

resource "azurerm_resource_group" "main" {
  name     = "rg-\${var.project_name}-\${var.environment}"
  location = var.location
  tags     = var.tags
}

resource "azurerm_virtual_network" "main" {
  name                = "vnet-\${var.project_name}-\${var.environment}"
  location            = azurerm_resource_group.main.location
  resource_group_name = azurerm_resource_group.main.name
  address_space       = var.vnet_address_space
  tags                = var.tags
}

resource "azurerm_subnet" "pe" {
  name                 = "snet-\${var.project_name}-\${var.environment}-pe"
  resource_group_name  = azurerm_resource_group.main.name
  virtual_network_name = azurerm_virtual_network.main.name
  address_prefixes     = var.pe_subnet_address_prefixes
}
EOF

  if needs_aks_subnet "${SELECTED_MODULES[@]}"; then
    cat <<EOF

resource "azurerm_subnet" "aks" {
  name                 = "snet-\${var.project_name}-\${var.environment}-aks"
  resource_group_name  = azurerm_resource_group.main.name
  virtual_network_name = azurerm_virtual_network.main.name
  address_prefixes     = var.aks_subnet_address_prefixes
}
EOF
  fi
  
  echo ""
  echo "# TODO: Add module blocks for selected modules"
}

# Minimal fallback variables.tf generator
generate_variables_tf_fallback() {
  local env_name="$1"
  
  cat <<EOF
# ===================================================================
# ${env_name^} Environment - Input Variables
# ===================================================================

variable "project_name" {
  description = "Name of the project"
  type        = string
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "${env_name}"
}

variable "location" {
  description = "Azure region"
  type        = string
  default     = "Southeast Asia"
}

variable "vnet_address_space" {
  description = "Address space for the VNet"
  type        = list(string)
  default     = ["10.10.0.0/16"]
}

variable "pe_subnet_address_prefixes" {
  description = "Address prefixes for Private Endpoint subnet"
  type        = list(string)
  default     = ["10.10.2.0/24"]
}

variable "tags" {
  description = "Resource tags"
  type        = map(string)
  default     = {}
}
EOF
}

# ===================================================================
# Diff and Summary Functions
# ===================================================================

# Print diff summary of substitutions
print_diff_summary() {
  local project_name="$1"
  local env_name="$2"
  
  echo ""
  echo -e "${BOLD}${BLUE}═══════════════════════════════════════════════════${NC}"
  echo -e "${BOLD}${BLUE}  Substitution Summary${NC}"
  echo -e "${BOLD}${BLUE}═══════════════════════════════════════════════════${NC}"
  echo ""
  echo -e "${BOLD}Template:${NC}     environments/uat/"
  echo -e "${BOLD}Target:${NC}       environments/${env_name}/"
  echo ""
  echo -e "${BOLD}Substitutions applied:${NC}"
  echo -e "  • ${YELLOW}\"uat\"${NC} → ${GREEN}\"${env_name}\"${NC} (all occurrences)"
  echo -e "  • ${YELLOW}\"UAT\"${NC} → ${GREEN}\"${env_name^^}\"${NC} (uppercase)"
  echo -e "  • ${YELLOW}rg-*-uat${NC} → ${GREEN}rg-*-${env_name}${NC}"
  echo -e "  • ${YELLOW}*-uat-*${NC} → ${GREEN}*-${env_name}-*${NC}"
  echo -e "  • ${YELLOW}project_name = \"...\"${NC} → ${GREEN}project_name = \"${project_name}\"${NC}"
  echo ""
  echo -e "${BOLD}Module filtering:${NC}"
  for module in "${SELECTED_MODULES[@]}"; do
    echo -e "  ${GREEN}✓${NC} ${module} (included)"
  done
  
  # List modules that were filtered out
  for module in "${MODULES[@]}"; do
    if ! is_module_selected "$module"; then
      echo -e "  ${RED}✗${NC} ${module} (excluded)"
    fi
  done
  echo ""
}

# ===================================================================
# Main Script
# ===================================================================

main() {
  echo -e "${BOLD}${CYAN}Terraform Environment Scaffolder${NC}"
  echo ""
  
  # Step 1: Get project name
  echo -e "${BOLD}Project name${NC} (e.g., cics, komopro):"
  read -r PROJECT_NAME
  
  if [ -z "$PROJECT_NAME" ]; then
    echo -e "${RED}Error: Project name cannot be empty${NC}"
    exit 1
  fi
  
  if ! [[ "$PROJECT_NAME" =~ ^[a-zA-Z0-9-]+$ ]]; then
    echo -e "${RED}Error: Project name must be alphanumeric with hyphens only${NC}"
    exit 1
  fi
  
  echo ""
  
  # Step 2: Get environment name
  echo -e "${BOLD}Environment name${NC} (e.g., cics-dev, cics-uat):"
  read -r ENV_NAME
  
  if [ -z "$ENV_NAME" ]; then
    echo -e "${RED}Error: Environment name cannot be empty${NC}"
    exit 1
  fi
  
  if ! [[ "$ENV_NAME" =~ ^[a-zA-Z0-9-]+$ ]]; then
    echo -e "${RED}Error: Environment name must be alphanumeric with hyphens only${NC}"
    exit 1
  fi
  
  echo ""
  
  # Step 3: Module selection
  show_module_selector
  clear
  
  echo -e "${GREEN}✓${NC} Selected modules:"
  for mod in "${SELECTED_MODULES[@]}"; do
    echo "  • $mod"
  done
  echo ""
  
  local output_dir="environments/${ENV_NAME}"
  
  # Step 4: Check if directory exists
  if [ -d "$output_dir" ]; then
    echo ""
    echo -e "${YELLOW}Warning: Directory '${output_dir}' already exists${NC}"
    echo -n "Overwrite? (y/N): "
    read -r confirm
    
    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
      echo -e "${RED}Aborted.${NC}"
      exit 0
    fi
  fi
  
  # Step 5: Create directory and generate files
  echo ""
  echo -e "${CYAN}Generating configuration from UAT template...${NC}"
  
  mkdir -p "$output_dir"
  
  # Generate main.tf
  echo -e "  ${CYAN}→${NC} Processing main.tf..."
  process_main_tf "$PROJECT_NAME" "$ENV_NAME" > "${output_dir}/main.tf"
  
  # Generate variables.tf
  echo -e "  ${CYAN}→${NC} Processing variables.tf..."
  process_variables_tf "$ENV_NAME" > "${output_dir}/variables.tf"
  
  # Generate terraform.tfvars
  echo -e "  ${CYAN}→${NC} Processing terraform.tfvars..."
  process_terraform_tfvars "$PROJECT_NAME" "$ENV_NAME" > "${output_dir}/terraform.tfvars"
  
  # Generate backend.tf (if exists in UAT)
  if [ -f "${UAT_ENV_DIR}/backend.tf" ]; then
    echo -e "  ${CYAN}→${NC} Processing backend.tf..."
    process_backend_tf "$ENV_NAME" > "${output_dir}/backend.tf"
  fi
  
  # Copy backend.hcl.example if it exists
  if [ -f "${UAT_ENV_DIR}/backend.hcl.example" ]; then
    echo -e "  ${CYAN}→${NC} Copying backend.hcl.example..."
    local backend_example=$(substitute_content "$(cat ${UAT_ENV_DIR}/backend.hcl.example)" "$PROJECT_NAME" "$ENV_NAME")
    echo "$backend_example" > "${output_dir}/backend.hcl.example"
  fi
  
  # Copy outputs.tf if it exists
  if [ -f "${UAT_ENV_DIR}/outputs.tf" ]; then
    echo -e "  ${CYAN}→${NC} Processing outputs.tf..."
    substitute_content "$(cat ${UAT_ENV_DIR}/outputs.tf)" "$PROJECT_NAME" "$ENV_NAME" > "${output_dir}/outputs.tf"
  fi
  
  # Copy providers.tf if it exists
  if [ -f "${UAT_ENV_DIR}/providers.tf" ]; then
    echo -e "  ${CYAN}→${NC} Processing providers.tf..."
    substitute_content "$(cat ${UAT_ENV_DIR}/providers.tf)" "$PROJECT_NAME" "$ENV_NAME" > "${output_dir}/providers.tf"
  fi
  
  # Print diff summary
  print_diff_summary "$PROJECT_NAME" "$ENV_NAME"
  
  # Step 6: Success summary
  echo -e "${GREEN}${BOLD}✓ Environment scaffolded successfully!${NC}"
  echo ""
  echo -e "${BOLD}Created files in ${output_dir}/${NC}"
  for file in "$output_dir"/*; do
    if [ -f "$file" ]; then
      local filename=$(basename "$file")
      local filesize=$(wc -l < "$file")
      echo -e "  ${GREEN}✓${NC} ${filename} (${filesize} lines)"
    fi
  done
  echo ""
  echo -e "${BOLD}Next steps:${NC}"
  echo "  1. Review generated files in ${output_dir}/"
  echo "  2. Update TODO placeholders and values in terraform.tfvars"
  echo "  3. Create backend.hcl from backend.hcl.example (if present)"
  echo "  4. Run: cd ${output_dir} && terraform init"
  echo "  5. Run: terraform plan"
  echo "  6. Run: terraform apply"
  echo ""
}

# Run main function
main

