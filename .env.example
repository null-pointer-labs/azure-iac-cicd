# ===================================================================
# Azure Terraform Scaffold - Environment Variables
# ===================================================================
# This file contains default values for the tf-scaffold.sh script
# Copy this to .env and update with your actual values
# ===================================================================

# ===================================================================
# Azure Subscription and Tenant
# ===================================================================
# Workload subscription (where your resources will be deployed)
WORKLOAD_SUBSCRIPTION_ID="9626c646-9572-4366-ae78-79fd3afdc48f"

# Azure AD Tenant ID
TENANT_ID="cf159a99-e27d-454d-ac31-f2ceef9acb8b"

# Default Azure location/region
LOCATION="Southeast Asia"

# ===================================================================
# Terraform Backend Configuration
# ===================================================================
# Backend subscription (where Terraform state storage account exists)
# Usually same as workload subscription, unless using centralized state management
BACKEND_SUBSCRIPTION_ID="9626c646-9572-4366-ae78-79fd3afdc48f"

# Backend storage account details
BACKEND_RESOURCE_GROUP="no-security"
BACKEND_STORAGE_ACCOUNT="egubibackendsa"
BACKEND_CONTAINER="tfstate"

# ===================================================================
# Private DNS Configuration (AUTOMATIC DETECTION)
# ===================================================================
# The scaffold automatically detects DNS mode based on these values:
#   • If BOTH DNS_SUBSCRIPTION_ID and DNS_ZONE_RG are set → Cross-Subscription mode
#   • If either is empty or missing → Standalone mode
# 
# Cross-Subscription mode: Uses existing DNS zones in hub subscription
# Standalone mode: Creates new DNS zones in workload subscription
# ===================================================================

# DNS Hub subscription (where shared Private DNS Zones exist)
# Set this ONLY if using Cross-Subscription DNS mode
DNS_SUBSCRIPTION_ID=""

# DNS resource group in hub subscription
# Set this ONLY if using Cross-Subscription DNS mode
DNS_ZONE_RG=""

# ===================================================================
# Notes:
# ===================================================================
# - Copy this file to .env: cp .env.example .env
# - Update .env with your actual values
# - .env is gitignored and won't be committed
# - tf-scaffold.sh automatically loads values from .env
# - DNS mode is auto-detected based on DNS_SUBSCRIPTION_ID and DNS_ZONE_RG
# - No more manual editing of backend.hcl or terraform.tfvars needed!
# ===================================================================
